# Optional Docker Compose overrides.
IMAGE_NAME=colorado-meshcore-site
WEB_PORT=3000

# Public site URL used for metadata, sitemap, and canonical links.
NEXT_PUBLIC_SITE_URL=https://meshcore.coloradomesh.org

# Runtime Leaflet tile settings exposed through /api/map/runtime. The default is OpenStreetMap if unset.
MESHCORE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
MESHCORE_MAP_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors
MESHCORE_MAP_DEFAULT_LATITUDE=39.5501
MESHCORE_MAP_DEFAULT_LONGITUDE=-105.7821
MESHCORE_MAP_DEFAULT_ZOOM=7

# Leave sample data unset to use it only when no live-map API or MQTT source is configured.
# Set MESHCORE_MAP_DEMO_MODE=true when intentionally running a public demo with sample data.
MESHCORE_MAP_SAMPLE_DATA=
MESHCORE_MAP_DEMO_MODE=false

# Preferred live source: a running yellowcooln/meshcore-mqtt-live-map-compatible /api/nodes endpoint.
# Example: MESHCORE_LIVE_MAP_API_URL=https://map.example.org/api/nodes
# With the optional Compose sidecar profile, set this to http://live-map:8080/api/nodes
# and set MESHCORE_LIVE_MAP_API_TOKEN to the same secret passed to the sidecar PROD_TOKEN.
MESHCORE_LIVE_MAP_API_URL=
# Optional token for PROD_MODE live-map instances. Required for the default sidecar profile.
# Kept server-side; never exposed to browsers.
MESHCORE_LIVE_MAP_API_TOKEN=
MESHCORE_LIVE_MAP_API_REFRESH_SECONDS=30
MESHCORE_LIVE_MAP_PROXY_TIMEOUT_MS=8000
MESHCORE_LIVE_MAP_PROXY_MAX_RESPONSE_BYTES=2000000

# Optional direct MQTT configuration. This is for JSON-compatible map payloads; raw MeshCore packet feeds
# should be decoded by meshcore-mqtt-live-map and consumed through MESHCORE_LIVE_MAP_API_URL.
# MESHCORE_MQTT_URL=mqtts://example-broker:8883
# MESHCORE_MQTT_USERNAME=
# MESHCORE_MQTT_PASSWORD=
# MESHCORE_MQTT_TOPIC=meshcore/#
# MESHCORE_MQTT_CLIENT_ID=colorado-meshcore-site

# Reserved for future map history support.
MESHCORE_MAP_HISTORY_ENABLED=false
